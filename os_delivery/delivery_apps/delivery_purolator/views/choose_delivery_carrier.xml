<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="choose_delivery_carrier_view_form_inherit" model="ir.ui.view">
        <field name="name">choose.delivery.carrier.form.inherit.purolator</field>
        <field name="model">choose.delivery.carrier</field>
        <field name="inherit_id" ref="delivery.choose_delivery_carrier_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='carrier_id']" position="after">
                <field invisible="delivery_type != 'purolator'" name="purolator_shipping_date"/>
            </xpath>
            <xpath expr="//group" position="inside">
                <group>
                    <field invisible="delivery_type != 'purolator'" name="purolator_total_weight"/>
                    <field invisible="delivery_type != 'purolator'" name="purolator_weight_unit"/>
                </group>
            </xpath>
            <xpath expr="//group[1]" position="after">
                <group>
                    <field domain="[('active','=',True)]" invisible="delivery_type != 'purolator'" name="purolator_service_type" widget="radio"/>
                    <field invisible="True" name="purolator_get_service" widget="radio"/>
                </group>
            </xpath></field>
    </record>
</odoo>
