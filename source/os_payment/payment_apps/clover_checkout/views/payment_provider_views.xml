    <record id="transaction_form_clover_checkout" model="ir.ui.view">
        <field name="name">acquirer.transaction.form.clover_checkout</field>
        <field name="model">payment.transaction</field>
        <field name="inherit_id" ref="payment.payment_transaction_form"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='provider_reference']" position="after">
                <field invisible="provider_code != 'clover_checkout'" name="clover_checkout_reference" readonly="1"/>
                <field invisible="provider_code != 'clover_checkout'" name="clover_checkout_merchant_transaction_id" readonly="1"/>
                <field invisible="provider_code != 'clover_checkout'" name="clover_checkout_merchant_id" readonly="1"/>
                <field groups="base.group_no_one" invisible="provider_code != 'clover_checkout'" name="clover_checkout_id"/>
                <field groups="base.group_no_one" invisible="provider_code != 'clover_checkout'" name="clover_data_id"/>
            </xpath>
            <!--            <xpath expr="//form" position="attributes">-->
            <!--                <attribute name="edit">true</attribute>-->
            <!--            </xpath>--></field>
    </record>
    <record id="payment_token_clover_checkout" model="ir.ui.view">
        <field name="name">acquirer.token.form.clover_checkout</field>
        <field name="model">payment.token</field>
        <field name="inherit_id" ref="payment.payment_token_form"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='partner_id']" position="after">
                <field invisible="1" name="provider_code"/>
                <field invisible="provider_code != 'clover_checkout'" name="clover_checkout_id" readonly="1"/>
                <field invisible="provider_code != 'clover_checkout'" name="clover_customer_id" readonly="1"/>
            </xpath>
            <!--            <xpath expr="//form" position="attributes">-->
            <!--                <attribute name="edit">true</attribute>-->
            <!--            </xpath>--></field>
    </record>

    <record id="payment_provider_form_clover_checkout" model="ir.ui.view">
        <field name="name">payment.provider.form.clover_checkout</field>
        <field name="model">payment.provider</field>
        <field name="inherit_id" ref="payment.payment_provider_form"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='allow_tokenization']" position="after">
                <field name="token"/>
                <field name="clover_public_api_key"/>
            </xpath>
        </field>
    </record>
</odoo>
