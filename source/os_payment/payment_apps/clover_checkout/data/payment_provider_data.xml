<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">

        <record id="payment_method_clover" model="payment.method">
            <field name="name">Clover Checkout</field>
            <field name="code">clover_checkout</field>
            <field name="sequence">1000</field>
            <field name="active">True</field>
             <field name="image" type="base64" file="os_payment/static/src/img/payment_clover_checkout/logo.svg"/>
            <field name="support_tokenization">False</field>
            <field name="support_express_checkout">False</field>
            <field name="support_refund">none</field>
        </record>
        <record id="account_payment_method_clover" model="account.payment.method">
            <field name="name">Clover Checkout</field>
            <field name="code">clover_checkout</field>
            <field name="payment_type">inbound</field>

        </record>
    </data>
</odoo>
