<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>

        <record id="odoosync_pos_payment_form_inherit" model="ir.ui.view">
            <field name="name">odoosync_pos_payment.form</field>
            <field name="model">omni.account</field>
            <field name="inherit_id" ref="odoosync_base.view_omni_account_form"/>
            <field name="priority" eval="8"/>
            <field name="arch" type="xml">
                <xpath expr="//notebook[@name='main_notebook']" position="inside">
                    <page string="POS Payment Acquirers" name="pos_payment_method_list">
                        <group>
                            <field name="pos_payment_methods_ids" options="{'create': false}"/>
                        </group>
                    </page>
                </xpath>

            </field>
        </record>
    </data>
</odoo>