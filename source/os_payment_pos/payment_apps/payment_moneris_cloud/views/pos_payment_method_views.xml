<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="pos_payment_method_view_form_inherit_pos_moneris" model="ir.ui.view">
        <field name="name">pos.payment.method.form.inherit.moneris</field>
        <field name="model">pos.payment.method</field>
        <field name="inherit_id" ref="point_of_sale.pos_payment_method_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='use_payment_terminal']" position="after">
                <field invisible="use_payment_terminal != 'moneris_cloud'" name="cloud_store_id" required="use_payment_terminal == 'moneris_cloud'"/>
                <field invisible="use_payment_terminal != 'moneris_cloud'" name="moneris_is_manual_payment" required="use_payment_terminal == 'moneris_cloud'"/>
                <field invisible="use_payment_terminal != 'moneris_cloud'" name="cloud_api_token" required="use_payment_terminal == 'moneris_cloud'"/>
                <field invisible="use_payment_terminal != 'moneris_cloud'" name="cloud_terminal_id" required="use_payment_terminal == 'moneris_cloud'"/>
                <field invisible="use_payment_terminal != 'moneris_cloud'" name="moneris_device_id" required="use_payment_terminal == 'moneris_cloud'"/>
                <field invisible="use_payment_terminal != 'moneris_cloud'" name="cloud_pairing_token" required="use_payment_terminal == 'moneris_cloud'"/>
                <field invisible="use_payment_terminal != 'moneris_cloud'" name="cloud_integration_method"/>
                <field invisible="use_payment_terminal != 'moneris_cloud' or cloud_integration_method in ['polling']" name="cloud_postback_url" required="cloud_integration_method == 'postbackurl'"/>
                <field invisible="use_payment_terminal != 'moneris_cloud'" name="cloud_cloud_environment"/>
                <field invisible="use_payment_terminal != 'moneris_cloud'" name="cloud_cloud_paired"/>
                <field invisible="use_payment_terminal != 'moneris_cloud'" name="is_moneris_go_cloud" readonly="1"/>
                <field invisible="use_payment_terminal != 'moneris_cloud'" name="account_id"/>
                <field invisible="use_payment_terminal != 'moneris_cloud'" name="token"/>
                <field invisible="use_payment_terminal != 'moneris_cloud'" name="omnisync_active" readonly="1"/>
                <button class="oe_highlight" groups="base.group_erp_manager" invisible="use_payment_terminal != 'moneris_cloud' or (cloud_cloud_environment == 'disabled' or cloud_cloud_paired == True)" name="cloud_terminal_pair" string="Pair" type="object"/>
                <br/>
                <button class="oe_highlight" groups="base.group_erp_manager" invisible="use_payment_terminal != 'moneris_cloud' or (cloud_cloud_environment == 'disabled' or cloud_cloud_paired == False)" name="cloud_terminal_init" string="Initilization" type="object"/>
                <button class="oe_highlight" groups="base.group_erp_manager" invisible="use_payment_terminal != 'moneris_cloud' or (cloud_cloud_environment == 'disabled' or cloud_cloud_paired == False)" name="cloud_terminal_unpair" string="Unpair" type="object"/>
            </xpath>
            <xpath expr="//form//sheet" position="inside">
                <notebook>
                    <page invisible="use_payment_terminal not in 'moneris_cloud'" string="Moneris TIP">
                        <group>
                            <group>
                                <field invisible="use_payment_terminal != 'moneris_cloud'" name="moneris_cloud_set_tip" readonly="1"/>
                                <field invisible="use_payment_terminal != 'moneris_cloud'" name="moneris_cloud_tip_percentage"/>
                                <field invisible="use_payment_terminal != 'moneris_cloud'" name="moneris_cloud_tip_amount"/>
                                <button class="oe_highlight" context="{'set_tip':True}" groups="base.group_erp_manager" invisible="use_payment_terminal != 'moneris_cloud' or (cloud_cloud_environment == 'disabled' or moneris_cloud_set_tip == True)" name="cloud_terminal_set_tip" string="Set Tip" type="object"/>
                                <button class="oe_highlight" context="{'set_tip':False}" groups="base.group_erp_manager" invisible="use_payment_terminal != 'moneris_cloud' or (cloud_cloud_environment == 'disabled' or moneris_cloud_set_tip == False)" name="cloud_terminal_set_tip" string="Remove Tip" type="object"/>
                            </group>
                            <group/>
                        </group>
                    </page>
                    <page invisible="use_payment_terminal != 'moneris_cloud'" string="Force Done Card Names">
                        <field name="force_done_card_name_ids" widget="many2many" context="{'default_terminal': 'moneris_cloud', 'tree_view_ref': 'os_payment_pos.pos_force_done_card_name_view_tree'}">
                            <list editable="bottom">
                                <field name="sequence" widget="handle"/>
                                <field name="name"/>
                                <field name="code"/>
                                <field name="terminal"/>
                            </list>
                            <form>
                                <group>
                                    <field name="name"/>
                                    <field name="code"/>
                                    <field name="terminal"/>
                                    <field name="sequence"/>
                                    <field name="active"/>
                                </group>
                            </form>
                        </field>
                    </page>
                </notebook>
            </xpath></field>
    </record>
    <record id="view_pos_pos_form_inherit_pos_moneris" model="ir.ui.view">
        <field name="name">pos.order.form.inherit.moneris</field>
        <field name="model">pos.order</field>
        <field name="inherit_id" ref="point_of_sale.view_pos_pos_form"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='fiscal_position_id']" position="after">
                <field invisible="1" name="moneris_cloud_cloudticket"/>
                <field name="moneris_cloud_receiptid"/>
                <field name="moneris_cloud_transid"/>
            </xpath></field>
    </record>
</odoo>
