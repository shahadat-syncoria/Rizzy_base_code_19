<odoo>
  <data>

    <record model="ir.ui.view" id="os_marketplace.list">
      <field name="name">Marketplace Instance list</field>
      <field name="model">marketplace.instance</field>
      <field name="arch" type="xml">
        <list create="false">
          <field name="marketplace_instance_type" invisible="0" optional="hide"/>
        </list>
      </field>
    </record>

    <record model="ir.actions.act_window" id="os_marketplace.action_window">
      <field name="name">Marketplace window</field>
      <field name="res_model">marketplace.instance</field>
      <field name="view_mode">list,form</field>
    </record>

    <record model="ir.actions.server" id="os_marketplace.action_server">
      <field name="name">os_marketplace server</field>
      <field name="model_id" ref="model_marketplace_instance"/>
      <field name="state">code</field>
      <field name="code">
        action = {
          "type": "ir.actions.act_window",
          "view_mode": "list,form",
          "res_model": model._name,
        }
      </field>
    </record>

    <record id="view_instance_form" model="ir.ui.view">
        <field name="name">marketplace.instance.form</field>
        <field name="model">marketplace.instance</field>
        <field name="arch" type="xml">
          <form string="Instances">
            <header>
            </header>
            <sheet>
                <group name="instance_header">
                    <group name="instance_details">
                      <field name="name"/>
                      <field name="marketplace_instance_type" widget="radio"/>
                    </group>
                </group>
            </sheet>
            <chatter/>
          </form>
        </field>
    </record>

    

    <menuitem id="syncoria_marketplace_main" name="Marketplace" sequence="1" web_icon="os_marketplace,static/description/icon.png"/>
    <menuitem action="os_marketplace.action_window" id="marketplace_dashboard" name="Marketplace List" parent="syncoria_marketplace_main" sequence="1"/>
    <menuitem id="marketplace_configuration" name="Configuration" parent="syncoria_marketplace_main" sequence="20"/>
    <menuitem action="os_marketplace.action_window" id="marketplace_configuration_settings" name="Settings" parent="marketplace_configuration"/>

  </data>
</odoo>