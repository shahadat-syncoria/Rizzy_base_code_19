<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>

        <record id="odoosync_delivery_form_inherit" model="ir.ui.view">
            <field name="name">odoosync_delivery.form</field>
            <field name="model">omni.account</field>
            <field name="inherit_id" ref="odoosync_base.view_omni_account_form"/>
            <field name="priority" eval="8"/>
            <field name="arch" type="xml">
                <xpath expr="//notebook[@name='main_notebook']" position="inside">
                    <page string="Delivery Carriers" name="delivery_list">
                        <group>
                            <field name="carrier_ids" options="{'create': false}"/>
                        </group>
                    </page>
                </xpath>

            </field>
        </record>
    </data>
</odoo>