<?xml version="1.0" encoding="UTF-8"?>
<templates id="template" xml:space="preserve">
    <t t-name="os_payment_pos.PreauthScreen">
        <div class="ticket-screen screen h-100 bg-100">
            <div class="screen-full-width d-flex w-100 h-100">
                <div class="rightpane pane-border d-flex flex-column flex-grow-1 w-100 h-100 h-lg-100 bg-200 overflow-y-auto">
                    <div t-if="state.loading"
                         class="loading-overlay d-flex flex-column justify-content-center align-items-center">
                        <i class="fa fa-spinner fa-spin fa-3x mb-3" title="Loading" aria-hidden="true"></i>
                        <span class="fs-5">Requesting for Void…</span>
                    </div>

                    <!-- Top Controls -->
                    <div class="controls d-grid d-sm-flex align-items-center justify-content-between gap-2 gap-sm-3 p-2 bg-300">
                        <div class="buttons d-flex gap-2">
                            <button class="discard btn btn-lg btn-light text-nowrap" t-on-click="backCloseScreen">
                                <i class="oi oi-chevron-left"/>
                                <span t-if="!ui.isSmall" class="ms-2">Back</span>
                            </button>
                        </div>

                        <!-- Search Bar -->
                        <SearchBar
                            config="getSearchBarConfig()"
                            placeholder="'Search Preauth Orders...'"
                            onSearch.bind="onSearch"
                            onFilterSelected.bind="onFilterSelected"
                        />

                        <!-- Pagination -->
                        <div class="item d-flex align-items-center justify-content-end">
                            <span class="page me-2">
                                <t t-esc="getPageNumber()"/>
                            </span>
                            <div class="page-controls d-flex align-items-center gap-1">
                                <button class="previous btn btn-light btn-lg"
                                        t-att-disabled="state.page === 1"
                                        t-on-click="prevPage">
                                    <i class="fa fa-fw fa-caret-left"></i>
                                </button>
                                <button class="next btn btn-light btn-lg"
                                        t-att-disabled="state.page * state.pageSize >= state.totalCount"
                                        t-on-click="nextPage">
                                    <i class="fa fa-fw fa-caret-right"></i>
                                </button>
                            </div>
                        </div>
                    </div>

                    <!-- Orders List -->
                    <div class="orders overflow-y-auto flex-grow-1">
                        <t t-if="state.preauthOrders.length">

                            <!-- Desktop Header -->
                            <div t-if="!ui.isSmall" class="header-row d-flex text-bg-700 fw-bolder">
                                <div class="col wide p-2">Date</div>
                                <div class="col wide p-2">Transaction Number</div>
                                <div class="col wide p-2">Order Number</div>
                                <div class="col p-2">Customer</div>
                                <div class="col p-2">Total Amount</div>
                                <div class="col narrow p-2">Status</div>
                                <div class="col very-narrow p-2"></div>
                            </div>

                            <!-- Desktop Rows -->
                            <t t-if="!ui.isSmall" t-foreach="state.preauthOrders" t-as="order" t-key="order.id">
                                <div class="order-row">
                                    <div class="col wide p-2"><t t-esc="getDate(order)"/></div>
                                    <div class="col wide p-2"><t t-esc="order.transaction_id"/></div>
                                    <div class="col wide p-2"><t t-esc="order.order_id"/></div>
                                    <div class="col p-2"><t t-esc="getPartner(order)"/></div>
                                    <div class="col end p-2"><t t-esc="getTotal(order)"/></div>
                                    <div class="col narrow p-2"><t t-esc="getStatusText(order)"/></div>
                                    <div class="col very-narrow delete-button p-2">
                                        <i class="fa fa-trash"
                                           aria-hidden="true"
                                           t-att-class="order.status !== 'confirmed' ? 'invisible' : ''"
                                           t-on-click.stop="order.status === 'confirmed' ? () => this.confirmDeleteOrder(order) : null"/>
                                    </div>
                                </div>

                            </t>

                            <!-- Mobile Rows -->
                            <t t-if="ui.isSmall" t-foreach="state.preauthOrders" t-as="order" t-key="order.id">
                                <div class="mobileOrderList order-row rounded-3 p-2 mb-2 border">
                                    <div class="d-flex justify-content-between">
                                        <span><strong>Date:</strong> <t t-esc="getDate(order)"/></span>
                                        <span><strong>Status:</strong> <t t-esc="getStatusText(order)"/></span>
                                    </div>
                                    <div><strong>Txn #:</strong> <t t-esc="order.transaction_id"/></div>
                                    <div><strong>Order #:</strong> <t t-esc="order.order_id"/></div>
                                    <div><strong>Customer:</strong> <t t-esc="getPartner(order)"/></div>
                                    <div><strong>Total:</strong> <t t-esc="getTotal(order)"/></div>
                                    <div class="col very-narrow delete-button p-2">
                                        <i class="fa fa-trash"
                                           aria-hidden="true"
                                           t-att-class="order.status !== 'confirmed' ? 'invisible' : ''"
                                           t-on-click.stop="order.status === 'confirmed' ? () => this.confirmDeleteOrder(order) : null"/>
                                    </div>

                                </div>
                            </t>

                        </t>

                        <!-- Empty State -->
                        <CenteredIcon t-else=""
                                      icon="'fa-shopping-cart fa-4x'"
                                      text="'No preauth orders found'"
                                      class="'h-100'"/>
                    </div>
                </div>
            </div>
        </div>
    </t>
</templates>
