<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>

           <record id="view_account_move_inherit_moneris_cloud" model="ir.ui.view">
            <field name="name">account.move.form.inherited.moneris.cloud</field>
            <field name="model">account.move</field>
            <field name="inherit_id" ref="account.view_move_form"/>
            <field name="arch" type="xml">
                <xpath expr="//div[hasclass('oe_button_box')]" position="inside">
                    <button class="oe_stat_button" icon="fa-credit-card" invisible="reconciled_payments_count == 0" name="button_open_payments" type="object">
                        <field name="reconciled_payments_count"/>
                        <span invisible="reconciled_payments_count > 1">
                            Refund
                        </span>
                        <span invisible="reconciled_payments_count <= 1">
                            Refunds
                        </span>

                </xpath></field>
        </record>

        

    </data>
</odoo>
