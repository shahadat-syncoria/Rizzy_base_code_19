<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>

        <!-- VIEWS -->

        <record id="view_move_form_shopify" model="ir.ui.view">
            <field name="name">account.move.form.shopify</field>
            <field name="model">account.move</field>
            <field name="inherit_id" ref="account.view_move_form"/>
            <field name="arch" type="xml">

                <!-- Shopify order reference on the invoice header -->
                <xpath expr="//form/sheet/group/group[@id='header_right_group']/div[@name='journal_div']" position="after">
                    <field name="shopify_order" readonly="1" force_save="1"/>
                </xpath>


            </field>
        </record>

        <record id="view_move_tree_shopify" model="ir.ui.view">
            <field name="name">account.move.list.shopify</field>
            <field name="model">account.move</field>
            <field name="inherit_id" ref="account.view_move_tree"/>
            <field name="arch" type="xml">
                <xpath expr="//list/field[@name='journal_id']" position="after">
                    <field name="shopify_order"/>
                </xpath>
            </field>
        </record>

    </data>
</odoo>
