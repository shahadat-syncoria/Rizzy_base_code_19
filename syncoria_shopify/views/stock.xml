<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record id="view_stock_picking_form" model="ir.ui.view">
            <field name="name">stock.picking</field>
            <field name="model">stock.picking</field>
            <field name="inherit_id" ref="stock.view_picking_form"/>
            <field name="arch" type="xml">
                <xpath expr="//field[@name='shipping_weight']" position="after">
                    <field invisible="1" name="shopify_track_updated"/>
                    <field invisible="1" name="marketplace_type"/>
                    <field invisible="1" name="sale_id"/>
                </xpath>
                <xpath expr="//notebook" position="inside">
                    <page string="Shopify">
                        <group>
                            <group>
                                <field name="marketplace_instance_id" readonly="1"/>
                                <field name="shopify_id" readonly="1"/>
                                <field name="shopify_order_id" readonly="1"/>
                                <field name="shopify_tracking_urls" readonly="0"/>
                                <field name="shopify_tracking_company" readonly="0"/>
                                <field name="shopify_tracking_number" readonly="0"/>
                                <field name="shopify_status" readonly="1"/>
                                <field name="shopify_service" readonly="1"/>
                                <field name="shopify_track_updated" readonly="1"/>
                            </group>
                            <group>
                            </group>
                        </group>
                    </page>
                </xpath>
                <xpath expr="//header" position="inside">
                    <button class="oe_highlight" invisible="shopify_order_id == False or state != 'done' or shopify_id != False" name="create_shopify_fulfillment" string="Create Shopify Fulfillment" type="object"/>
                    <!--                    <button name="return_shopify_fulfillment" string="Return Shopify Fullfillment" type="object" class="oe_highlight" attrs="{ 'invisible' :['|', ('shopify_track_updated','=', True), '|', ('sale_id','=', False), '|' , ('picking_type_code', '=','outgoing'), '|', ('state','not in','done'), ('shopify_track_updated','=',True)] }" /> &ndash;&gt;-->
                    <!-- <button name="update_shopify_tracking" string="Update Shopify Tracking" type="object" class="oe_highlight" attrs="{ 'invisible' :['|', ('sale_id','=', False), '|', ('state','not in','done'), ('shopify_track_updated','=',True)] }" /> -->
                    <!-- <button name="get_order_fullfillments" string="Get Order Fullfillments" type="object" class="oe_highlight"/> -->
                    <!--                    <button name="get_order_fullfillments" string="Fetch Fulfilment" type="object"/>-->
                    <!--                    <button name="process_shopify_fulfilment" string="Process Fulfilment" type="object"/>-->
                </xpath></field>
        </record>
    </data>
</odoo>
